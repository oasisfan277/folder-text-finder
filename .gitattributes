# Normalize line endings. Text files are stored as LF in the repository
# and checked out as LF, which stops CRLF/LF churn between Windows editors
# and git on every commit.
* text=auto eol=lf

# Explicit text types
*.py    text eol=lf
*.md    text eol=lf
*.ini   text eol=lf
*.tpl   text eol=lf
*.html  text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.cfg   text eol=lf

# Binary files (never touch line endings)
*.nvda-addon binary
*.png        binary
*.ico        binary
*.pdf        binary
*.docx       binary
*.odt        binary
*.rtf        binary
